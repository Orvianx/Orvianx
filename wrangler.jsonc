{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "orvianx",
	"compatibility_date": "2026-05-04",
	"observability": {
		"enabled": true
	},
	"main": "dist/_worker.js",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": "dist"
	}
}
